# PostgreSQL
POSTGRES_SERVER=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# REST API auth: sent as the X-API-Token header. Empty → the API is disabled (503).
API_TOKEN=

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_WEBHOOK_URL=https://your_domain.com/webhook
# Required to register a webhook; Telegram echoes it back for verification.
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here
TELEGRAM_ADMIN_IDS=[123456789]

# Access control: open | whitelist | closed (see app/core/config.py).
# whitelist → only admins + ALLOWED_TELEGRAM_IDS may use the bot; others are ignored.
BOT_ACCESS_MODE=whitelist
ALLOWED_TELEGRAM_IDS=

# Certbot
CERTBOT_EMAIL=your_email@example.com
DOMAIN=nutricore.cloud

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000
# Retries for transient OpenAI errors (429 / 5xx / network); SDK backoff. 0 = off.
OPENAI_MAX_RETRIES=2

# Application Settings
DEBUG=true
ENVIRONMENT=development
# Host allowlist for TrustedHostMiddleware. Loopback-only by default; add your
# domain in production (e.g. ["nutricore.cloud"]).
ALLOWED_HOSTS=["127.0.0.1","localhost"]

# Nutrition Analysis Settings
DEFAULT_TIMEZONE=Asia/Tbilisi

# Consult relay (my-health hub integration)
MYHEALTH_CONSULT_URL=http://127.0.0.1:8787/consult
CONSULT_TOKEN=your_consult_token_here
